# LearnByPlay — Environment Variables
# Copy this file to .env.local and customize as needed.

# Path to the SQLite database file (default: data/learnbyplay.db)
# LEARNBYPLAY_DB_PATH=data/learnbyplay.db

# Public base URL used for sitemap, robots.txt, and OpenGraph metadata
# NEXT_PUBLIC_BASE_URL=https://learnbyplay.example.com
